# Copy to .env and fill in real values before running `docker compose up`.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# "backend" must stay in this list — Next.js reaches Django using the Docker
# service name as the Host header, and Django rejects unrecognized hosts.
DJANGO_ALLOWED_HOSTS=your-domain.co.zw,localhost,backend

# Postgres
DB_NAME=musikawehuku
DB_USER=musikawehuku
DB_PASSWORD=change-me

# CORS (only relevant if the frontend is ever hosted on a different origin)
CORS_ALLOWED_ORIGINS=http://your-domain.co.zw

# Set to true only after Nginx is terminating HTTPS for real — a Secure cookie
# set over plain HTTP gets silently dropped by browsers on the next request.
COOKIE_SECURE=false

# Business rules
PLATFORM_COMMISSION_RATE=0.02
SELLER_LISTING_FEE=1.00
BOOKING_HOLD_HOURS=48
BOOKING_DEPOSIT_RATE=0.3
